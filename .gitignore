# Python-generated files
__pycache__/
*.py[oc]
build/
dist/
wheels/
*.egg-info

# Virtual environments
.venv

# Local secrets / config (keep .env.example tracked)
.env
.env.*
!.env.example

# Watermark state contains routing targets (group ids, phone numbers) and a
# mutable placing -- never commit it. Keep only the sanitized example.
watermarks*.json
!watermarks.example.json
